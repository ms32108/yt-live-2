name: Restream Latest Live from other chanels
on:
  schedule:
    - cron: '0 14 * * *' # Runs every day at 7:30 PM IST
  workflow_dispatch:

jobs:
  stream:
    runs-on: ubuntu-latest
    steps:
      - name: Install yt-dlp & FFmpeg
        run: |
          sudo curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o /usr/local/bin/yt-dlp
          sudo chmod a+rx /usr/local/bin/yt-dlp
          sudo apt-get update && sudo apt-get install -y ffmpeg

      - name: Download and Stream
        env:
          STREAM_KEY: ${{ secrets.STREAM_KEY }}
        run: |
          CHANNEL_URL="PASTE_TARGET_CHANNEL_URL_HERE"
          RTMP_URL="rtmp://a.rtmp.youtube.com/live2"
          
          yt-dlp --playlist-items 1 --format "bv+ba/b" --output "video.mp4" "$CHANNEL_URL"
          
          ffmpeg -re -i video.mp4 -c:v copy -c:a copy -f flv "$RTMP_URL/$STREAM_KEY"
